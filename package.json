{
  "name": "rigstore-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm --prefix apps/backend run dev\" \"npm --prefix apps/frontend run dev\"",
    "build": "npm run build --workspaces",
    "db:generate": "npm run generate --workspace=@rigstore/database",
    "db:push": "npm run push --workspace=@rigstore/database",
    "postinstall": "npm run db:generate"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
